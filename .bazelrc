# Repository-wide Bazel defaults. Keep credentials and machine-local options in
# .bazelrc.local, which is intentionally ignored by git.

common --color=auto
common --curses=auto

build --verbose_failures

test --test_output=errors
test --test_summary=short

# Opt-in build modes:
#   bazel build --config=debug //...
#   bazel build --config=release //...
#   bazel build --config=clang //...
#   bazel build --config=gcc-ci //...
#   bazel test --config=asan //...
build:debug -c dbg

build:release -c opt

build:clang --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
build:clang --extra_toolchains=@llvm_toolchain//:all

build:gcc-ci --repo_env=CC=/usr/bin/gcc
build:gcc-ci --action_env=CC=/usr/bin/gcc
build:gcc-ci --cxxopt=-std=c++20

build:asan --copt=-fsanitize=address
build:asan --linkopt=-fsanitize=address
build:asan --strip=never
test:asan --test_env=ASAN_OPTIONS=detect_leaks=1

# Opt-in remote cache/BES:
#   bazel build --config=remote //...
# Put remote_header/API keys in .bazelrc.local.
build:remote --bes_results_url=https://app.buildbuddy.io/invocation/
build:remote --bes_backend=grpcs://remote.buildbuddy.io
build:remote --remote_cache=grpcs://remote.buildbuddy.io
build:remote --remote_timeout=10m

try-import %workspace%/.bazelrc.local
