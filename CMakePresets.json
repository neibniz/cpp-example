{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/${presetName}/generators/conan_toolchain.cmake",
        "BUILD_TESTING": "OFF",
        "PROJECT_ENABLE_BENCHMARKS": "OFF",
        "PROJECT_ENABLE_COVERAGE": "OFF",
        "PROJECT_ENABLE_TESTS": "OFF",
        "PROJECT_ENABLE_WARNINGS": "ON",
        "PROJECT_SANITIZER": "none"
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "debug-base"
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Release With Debug Info",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "minsizerel",
      "displayName": "Minimum Size Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "asan",
      "displayName": "AddressSanitizer",
      "inherits": "debug-base",
      "cacheVariables": {
        "PROJECT_SANITIZER": "address"
      }
    },
    {
      "name": "ubsan",
      "displayName": "UndefinedBehaviorSanitizer",
      "inherits": "debug-base",
      "cacheVariables": {
        "PROJECT_SANITIZER": "undefined"
      }
    },
    {
      "name": "asan-ubsan",
      "displayName": "AddressSanitizer + UndefinedBehaviorSanitizer",
      "inherits": "debug-base",
      "cacheVariables": {
        "PROJECT_SANITIZER": "address-undefined"
      }
    },
    {
      "name": "tsan",
      "displayName": "ThreadSanitizer",
      "inherits": "debug-base",
      "cacheVariables": {
        "PROJECT_SANITIZER": "thread"
      }
    },
    {
      "name": "test",
      "displayName": "Tests",
      "inherits": "debug-base",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "PROJECT_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage",
      "inherits": "test",
      "cacheVariables": {
        "PROJECT_ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "benchmark",
      "displayName": "Benchmarks",
      "inherits": "base",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "PROJECT_ENABLE_BENCHMARKS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "minsizerel",
      "configurePreset": "minsizerel"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "ubsan",
      "configurePreset": "ubsan"
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "test",
      "configurePreset": "test"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "benchmark",
      "configurePreset": "benchmark"
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "configurePreset": "test",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "benchmark",
      "configurePreset": "benchmark",
      "filter": {
        "include": {
          "label": "benchmark"
        }
      },
      "output": {
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "test",
      "steps": [
        {
          "type": "configure",
          "name": "test"
        },
        {
          "type": "build",
          "name": "test"
        },
        {
          "type": "test",
          "name": "test"
        }
      ]
    },
    {
      "name": "coverage",
      "steps": [
        {
          "type": "configure",
          "name": "coverage"
        },
        {
          "type": "build",
          "name": "coverage"
        },
        {
          "type": "test",
          "name": "coverage"
        }
      ]
    },
    {
      "name": "benchmark",
      "steps": [
        {
          "type": "configure",
          "name": "benchmark"
        },
        {
          "type": "build",
          "name": "benchmark"
        },
        {
          "type": "test",
          "name": "benchmark"
        }
      ]
    }
  ]
}
