---
# 指定语言为 C++。
Language: Cpp

# 基于 LLVM 官方代码风格。
# 这是 LLVM/Clang/MLIR 等项目常用的基础风格。
BasedOnStyle: LLVM

# 按 C++20 语法理解代码。
# 如果项目使用 C++23，可以改成 c++23。
Standard: c++20

# 每行最大宽度。
# LLVM 默认通常偏 80，这里放宽到 100，更适合现代服务端/基础软件项目。
ColumnLimit: 100

# 缩进宽度。
# LLVM 风格通常使用 2 空格缩进。
IndentWidth: 2

# Tab 显示宽度。
TabWidth: 2

# 不使用 Tab，只使用空格。
UseTab: Never

# public/private/protected 相对于 class 的缩进偏移。
# -2 表示访问控制符向左退一级。
#
# class Foo {
# public:
#   void run();
#
# private:
#   int value_;
# };
AccessModifierOffset: -2

# namespace 内部不额外缩进。
#
# namespace net {
#
# class TcpServer {};
#
# } // namespace net
NamespaceIndentation: None

# case 标签不额外缩进。
#
# switch (state) {
# case State::Init:
#   break;
# }
IndentCaseLabels: false

# case 内部代码块不额外增加一层 block 缩进。
IndentCaseBlocks: false

# goto label 是否缩进。
IndentGotoLabels: true

# 预处理指令不额外缩进。
#
# #ifdef DEBUG
# #define LOG_LEVEL 1
# #endif
IndentPPDirectives: None

# extern "C" block 的缩进策略。
# AfterExternBlock 表示跟随 extern block 的形式处理。
IndentExternBlock: AfterExternBlock

# 换行后的继续缩进宽度。
#
# auto value = someVeryLongFunction(firstArgument,
#                                  secondArgument);
ContinuationIndentWidth: 4

# 构造函数初始化列表换行后的缩进宽度。
#
# Foo::Foo()
#     : a_(1), b_(2) {}
ConstructorInitializerIndentWidth: 4

# 左大括号跟在声明/语句后面。
#
# void run() {
#   work();
# }
BreakBeforeBraces: Attach

# 大括号细节配置。
# 当前 BreakBeforeBraces 使用 Attach，下面大部分字段主要作为显式说明。
BraceWrapping:
  # case 后不单独换行放大括号。
  AfterCaseLabel: false

  # class 左大括号不另起一行。
  AfterClass: false

  # if/for/while/switch 左大括号不另起一行。
  AfterControlStatement: Never

  # enum 左大括号不另起一行。
  AfterEnum: false

  # function 左大括号不另起一行。
  AfterFunction: false

  # namespace 左大括号不另起一行。
  AfterNamespace: false

  # ObjC 声明左大括号不另起一行，C++ 项目通常无影响。
  AfterObjCDeclaration: false

  # struct 左大括号不另起一行。
  AfterStruct: false

  # union 左大括号不另起一行。
  AfterUnion: false

  # extern block 左大括号不另起一行。
  AfterExternBlock: false

  # catch 前不额外换行。
  BeforeCatch: false

  # else 前不额外换行。
  BeforeElse: false

  # lambda body 前不额外换行。
  BeforeLambdaBody: false

  # do-while 的 while 前不额外换行。
  BeforeWhile: false

  # 大括号本身不缩进。
  IndentBraces: false

  # 空函数允许拆分或保持简洁形式。
  SplitEmptyFunction: true

  # 空 record，例如空 class/struct，可以拆分。
  SplitEmptyRecord: true

  # 空 namespace 可以拆分。
  SplitEmptyNamespace: true

# 不允许短 enum 放在单行，增强 diff 友好性。
AllowShortEnumsOnASingleLine: false

# 只有空函数允许单行。
#
# void foo() {}
#
# 非空函数会展开。
AllowShortFunctionsOnASingleLine: Empty

# 不允许短 if 单行。
#
# if (ok)
#   return;
#
# 而不是：
# if (ok) return;
AllowShortIfStatementsOnASingleLine: Never

# 不允许短循环单行。
AllowShortLoopsOnASingleLine: false

# 不允许短代码块单行。
AllowShortBlocksOnASingleLine: Never

# 不允许短 case label 单行。
AllowShortCaseLabelsOnASingleLine: false

# 短 lambda 在内联场景中可以单行。
#
# auto f = [] { return 1; };
AllowShortLambdasOnASingleLine: Inline

# 函数调用参数尽量打包到同一行。
#
# foo(a, b, c);
#
# 如果你想一个参数一行，可以改成 false。
BinPackArguments: true

# 函数声明参数尽量打包到同一行。
BinPackParameters: true

# 当参数太长时，允许所有实参换到下一行。
AllowAllArgumentsOnNextLine: true

# 当参数太长时，允许所有形参换到下一行。
AllowAllParametersOfDeclarationOnNextLine: true

# 左括号后换行时，参数与左括号对齐。
#
# foo(firstArgument,
#     secondArgument);
AlignAfterOpenBracket: Align

# 结构体数组初始化时的对齐方式。
AlignArrayOfStructures: Left

# 不强制连续赋值对齐。
#
# int a = 1;
# int longName = 2;
#
# 而不是强行对齐等号。
AlignConsecutiveAssignments: None

# 不强制连续 bitfield 对齐。
AlignConsecutiveBitFields: None

# 不强制连续声明对齐。
AlignConsecutiveDeclarations: None

# 不强制连续宏定义对齐。
AlignConsecutiveMacros: None

# 反斜杠续行的对齐方式。
AlignEscapedNewlines: Right

# 多行表达式中的操作数对齐。
#
# auto x = firstValue +
#          secondValue;
AlignOperands: Align

# 对齐行尾注释。
#
# int fd = -1;       // socket fd
# int timeout = 30;  // seconds
AlignTrailingComments: true

# 指针星号靠右，LLVM 风格。
#
# int *ptr;
PointerAlignment: Right

# 引用符号跟随指针规则。
#
# const std::string &name;
ReferenceAlignment: Pointer

# 不根据已有代码自动推导指针风格，强制使用上面的 PointerAlignment。
DerivePointerAlignment: false

# 只在控制语句后加空格。
#
# if (ok)
# for (...)
#
# 函数调用不加：
# foo();
SpaceBeforeParens: ControlStatements

# range-for 的冒号前保留空格。
#
# for (const auto &x : values)
SpaceBeforeRangeBasedForLoopColon: true

# 空括号内不加空格。
#
# foo()
SpaceInEmptyParentheses: false

# 普通括号内不加空格。
#
# foo(x)
# 而不是 foo( x )
SpacesInParentheses: false

# 方括号内不加空格。
#
# arr[i]
SpacesInSquareBrackets: false

# 模板尖括号内不加空格。
#
# std::vector<int>
SpacesInAngles: Never

# template 关键字后不加额外空格。
SpaceAfterTemplateKeyword: false

# C++11 braced list 前不加额外空格。
#
# Foo foo{1, 2};
SpaceBeforeCpp11BracedList: false

# 使用 C++11 braced list 风格。
Cpp11BracedListStyle: true

# include 排序区分大小写。
SortIncludes: CaseSensitive

# include 按类别重新分组。
IncludeBlocks: Regroup

# include 分组规则。
IncludeCategories:
  # 如果是 LLVM/Clang 相关项目，这组优先。
  # 普通业务项目可以把这里改成自己的项目名前缀，例如 "^\"my_project/"。
  - Regex: '^"(llvm|llvm-c|clang|clang-c|lld|lldb)/'
    Priority: 1

  # 项目内部头文件。
  - Regex: '^"[^"]*"'
    Priority: 2

  # C++ 标准库头文件，例如 <vector>、<string>。
  - Regex: '^<[^.]+>$'
    Priority: 3

  # 其他系统库或第三方库头文件。
  - Regex: '^<.*>$'
    Priority: 4

# 自动重排长注释。
ReflowComments: true

# 允许自动拆分长字符串字面量。
BreakStringLiterals: true

# 代码块开头不保留空行。
KeepEmptyLinesAtTheStartOfBlocks: false

# 最多保留一个连续空行。
MaxEmptyLinesToKeep: 1

# 自动修复 namespace 结尾注释。
#
# } // namespace net
FixNamespaceComments: true

# 不压缩多层 namespace。
#
# namespace a {
# namespace b {
# }
# }
#
# 如果你更喜欢 namespace a::b，可以改成 true。
CompactNamespaces: false

# 自动推导文件换行符。
DeriveLineEnding: true

# 不使用 Windows CRLF。
UseCRLF: false
...